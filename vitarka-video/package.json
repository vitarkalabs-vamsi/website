{
  "name": "vitarka-video",
  "version": "1.0.0",
  "description": "Vitarka Labs promotional video — built with Remotion",
  "private": true,
  "scripts": {
    "start": "remotion studio",
    "build": "remotion render VitarkaPromo out/vitarka-promo.mp4",
    "render": "remotion render VitarkaPromo out/vitarka-promo.mp4 --codec h264",
    "preview": "remotion studio"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remotion": "^4.0.0",
    "@remotion/cli": "^4.0.0",
    "@remotion/renderer": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.3.0"
  },
  "remotion": {
    "entryPoint": "src/index.ts"
  }
}
